# =====================================================
# Linny Server - Environment Variables
# =====================================================
# Copy this file to .env and fill in the values

# -------------------
# Server Configuration
# -------------------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# -------------------
# Database Configuration
# -------------------
# For Docker Compose:
# DATABASE_URL=postgresql://neo_linear:neo_linear_password@postgres:5432/neo_linear

# For local development:
# DATABASE_URL=postgresql://neo_linear:neo_linear_password@localhost:5432/neo_linear

# For production (replace with actual values):
# DATABASE_URL=postgresql://user:password@host:5432/database

# -------------------
# Redis Cache (Optional)
# -------------------
# For Docker Compose:
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ENABLED=true
REDIS_PREFIX=neo_linear:

# For local development:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_ENABLED=true
# REDIS_PREFIX=neo_linear:

# JWT Configuration
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET=change-this-secret-in-production-use-at-least-32-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Security Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# IMPORTANT: Change this to a secure random string in production!
CSRF_SECRET=change-this-secret-in-production

# Rate Limiting Configuration
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100
READ_RATE_LIMIT_WINDOW_MS=900000
READ_RATE_LIMIT_MAX=200

# Account Lockout Configuration
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_WINDOW_MS=900000

# Email Configuration
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@example.com

# Logging Configuration
# Options: error, warn, info, debug
LOG_LEVEL=info

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
