{
  "name": "neo-linear-server",
  "version": "1.0.0",
  "description": "Neo Linear backend server with PostgreSQL",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx seed.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json}\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "migrate:data": "tsx scripts/migrate-to-postgres.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/express": "^4.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@neo-linear/contracts": "file:../packages/contracts",
    "@prisma/client": "^6.1.0",
    "@types/axios": "^0.9.36",
    "@types/bull": "^3.15.9",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.5",
    "dompurify": "^3.3.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.7.1",
    "fastify-type-provider-zod": "^3.0.0",
    "ioredis": "^5.9.2",
    "isomorphic-dompurify": "^2.35.0",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "winston": "^3.11.0",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.23.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
