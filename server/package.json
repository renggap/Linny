{
  "name": "linear-clone-server",
  "version": "1.0.0",
  "description": "Linear Clone backend server with SQLite",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx seed.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/axios": "^0.9.36",
    "@types/bull": "^3.15.9",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^3.0.1",
    "helmet": "^8.0.0",
    "isomorphic-dompurify": "^2.35.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "sql.js": "^1.12.0",
    "winston": "^3.11.0",
    "ws": "^8.18.3",
    "zod": "^3.24.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}