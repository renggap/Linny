{
  "name": "neo-linear",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:frontend": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "vite build",
    "build:server": "cd server && npm run build",
    "preview": "vite preview",
    "seed": "tsx server/seed.ts",
    "seed:force": "tsx server/seed.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@neo-linear/contracts": "file:./packages/contracts",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-router": "^1.151.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.26.2",
    "lucide-react": "^0.468.0",
    "react": "^19.1.4",
    "react-dom": "^19.1.4",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.1.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.0"
  }
}
